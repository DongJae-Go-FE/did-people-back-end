generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Member {
  id                   BigInt      @id @default(autoincrement())
  createdAt            DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  name                 String?
  age                  BigInt?
  nation               String?
  parish               String?
  cathedral            String?
  phone                String?
  emergencyNum         String?     @map("emergency_num")
  profile              String?
  qr                   String?
  diocese              String?
  chosenDiocese        String?     @map("chosen_diocese")
  region               String?
  assignedChurchgoerId BigInt?     @map("assigned_churchgoer_id")
  assignedChurchgoer   Churchgoer? @relation(fields: [assignedChurchgoerId], references: [id])

  @@map("members")
}

model LoginData {
  id                    BigInt    @id @default(autoincrement())
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  idEmail               String?
  password              String?
  role                  String?   @default("manager")
  region                String?
  nave                  String?
  accessToken           String?
  refreshToken          String?
  refreshTokenExpiresAt DateTime? @db.Timestamptz()

  @@map("loginData")
}

model Churchgoer {
  id                 BigInt    @id @default(autoincrement())
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  name               String?
  baptismalName      String?   @map("baptismal_name")
  phone              String?
  address            String?
  diocese            String?
  region             String?
  parish             String?
  district           String?
  ban                String?
  familyType         String?   @map("family_type")
  childrenCount      BigInt?   @map("children_count")
  familyTypeOther    String?   @map("family_type_other")
  housingType        String?   @map("housing_type")
  housingTypeOther   String?   @map("housing_type_other")
  pilgrimGender      String?   @map("pilgrim_gender")
  clergyAcceptable   Boolean?  @map("clergy_acceptable")
  bedroomType        String?   @map("bedroom_type")
  bedCount           BigInt?   @map("bed_count")
  futonCount         BigInt?   @map("futon_count")
  bathroomType       String?   @map("bathroom_type")
  hasPet             Boolean?  @map("has_pet")
  petType            String?   @map("pet_type")
  petLocation        String?   @map("pet_location")
  hasWifi            Boolean?  @map("has_wifi")
  hasWasher          Boolean?  @map("has_washer")
  smokingPolicy      String?   @map("smoking_policy")
  transportationType String?   @map("transportation_type")
  breakfastAvailable Boolean?  @default(false) @map("breakfast_available")
  dinnerAvailable    Boolean?  @default(false) @map("dinner_available")
  availableRooms     BigInt?   @map("available_rooms")
  maxCapacity        BigInt?   @map("max_capacity")
  notes              String?
  assignedMembers    Member[]

  @@map("churchgoers")
}
